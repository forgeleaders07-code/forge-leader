{
  "name": "forge-des-leaders-lms",
  "version": "0.1.0",
  "private": true,
  "description": "La Forge des Leaders LMS — campus numérique privé de formation en ligne",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run start:dev --workspace apps/api",
    "dev:web": "npm run dev --workspace apps/web",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "prisma:generate": "npm run prisma:generate --workspace apps/api",
    "prisma:migrate": "npm run prisma:migrate --workspace apps/api"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
