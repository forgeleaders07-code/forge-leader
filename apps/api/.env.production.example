# Variables d'environnement de l'API en PRODUCTION (à saisir dans Railway).
# Copiez les VALEURS des secrets depuis votre fichier local apps/api/.env
# (ne mettez jamais les vraies valeurs dans un fichier committé sur GitHub).

# ── Base de données Neon (mêmes valeurs que le local)
DATABASE_URL="postgresql://…-pooler…neon.tech/neondb?sslmode=require&channel_binding=require"
DIRECT_URL="postgresql://…（sans -pooler）…neon.tech/neondb?sslmode=require&channel_binding=require"

# ── Auth (RECOPIEZ exactement les secrets de votre apps/api/.env local)
JWT_ACCESS_SECRET="…"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="…"
JWT_REFRESH_TTL_DAYS=30

# ── Webhook Systeme.io
SYSTEME_IO_WEBHOOK_SECRET="…"

# ── URL PUBLIQUE du frontend (fournie par Vercel après déploiement).
# Plusieurs origines possibles, séparées par des virgules.
FRONTEND_URL="https://votre-app.vercel.app"

# ── Emails (facultatif ; sans domaine vérifié, garder onboarding@resend.dev)
RESEND_API_KEY=""
MAIL_FROM="La Forge des Leaders <onboarding@resend.dev>"

# ── Cloudflare Stream (facultatif — vide = adaptateur vidéo de dev)
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_STREAM_API_TOKEN=""
CLOUDFLARE_STREAM_SIGNING_KEY_ID=""
CLOUDFLARE_STREAM_SIGNING_KEY_PEM=""
VIDEO_PLAYBACK_TOKEN_TTL=3600

# ── PORT : NE PAS définir — Railway l'injecte automatiquement.
