# ── Base de données (Neon PostgreSQL en production, Postgres local en dev)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/forge_lms?schema=public"

# ── API
PORT=3001
FRONTEND_URL="http://localhost:3000"

# ── Auth (générer des secrets forts : openssl rand -base64 48)
JWT_ACCESS_SECRET="change-me-access"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_SECRET="change-me-refresh"
JWT_REFRESH_TTL_DAYS=30

# ── Webhook Systeme.io (secret partagé configuré dans Systeme.io)
SYSTEME_IO_WEBHOOK_SECRET="change-me-webhook"

# ── Cloudflare Stream
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_STREAM_API_TOKEN=""
# Clé de signature des tokens de lecture (Stream > Signing Keys)
CLOUDFLARE_STREAM_SIGNING_KEY_ID=""
CLOUDFLARE_STREAM_SIGNING_KEY_PEM=""
# Durée de validité d'un token de lecture vidéo (secondes)
VIDEO_PLAYBACK_TOKEN_TTL=3600

# ── Emails (laisser vide en dev → les emails sont logués en console)
RESEND_API_KEY=""
MAIL_FROM="La Forge des Leaders <no-reply@laforgedesleaders.com>"
